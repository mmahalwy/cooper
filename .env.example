# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required by Supabase SSR helper (publishable key alias)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Slack ────────────────────────────────────────────────────────────────────
# From your Slack app's "Basic Information" page
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Optional Integrations ────────────────────────────────────────────────────
# Composio — third-party tool integrations
COMPOSIO_API_KEY=

# E2B — secure code sandbox
E2B_API_KEY=

# Resend — transactional email
RESEND_API_KEY=
RESEND_SEGMENT_ID=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret used to authenticate Vercel cron job requests
CRON_SECRET=
