{
    "display_information": {
        "name": "Cooper",
        "description": "Your sharp, witty AI teammate — right in Slack",
        "background_color": "#1a1a2e",
        "long_description": "Cooper is your AI-powered teammate that lives in Slack. DM Cooper or @mention it in any channel to get help with tasks, look up data from your connected tools, run code, schedule recurring reports, and more. Cooper remembers your team's context across conversations."
    },
    "features": {
